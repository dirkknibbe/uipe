{
  "name": "ui-perception-engine",
  "version": "0.1.0",
  "description": "Perception layer for AI agents — fuses visual + structural + temporal data into a UI Scene Graph",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
