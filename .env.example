# Vision model configuration
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3-vl:8b
OLLAMA_TIMEOUT_MS=180000
OMNIPARSER_URL=http://localhost:8100
OMNIPARSER_TIMEOUT_MS=120000

# Claude API (Tier C — deep analysis, optional)
ANTHROPIC_API_KEY=sk-ant-...

# Frame capture
FRAME_CAPTURE_BASE_FPS=5
FRAME_CAPTURE_BURST_FPS=15
FRAME_CAPTURE_BURST_DURATION_MS=3000
FRAME_DIFF_THRESHOLD=5
PIXEL_DIFF_THRESHOLD=0.05

# Browser
BROWSER_HEADLESS=true
BROWSER_VIEWPORT_WIDTH=1280
BROWSER_VIEWPORT_HEIGHT=720

# Temporal
MAX_SCENE_GRAPH_HISTORY=10
MAX_TRANSITION_HISTORY=50
